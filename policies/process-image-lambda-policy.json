{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadIncomingImages",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::YOUR-UPLOAD-BUCKET/uploads/*"
    },
    {
      "Sid": "WriteProcessedImagesAndMetadata",
      "Effect": "Allow",
      "Action": ["s3:PutObject"],
      "Resource": [
        "arn:aws:s3:::YOUR-UPLOAD-BUCKET/processed/*",
        "arn:aws:s3:::YOUR-UPLOAD-BUCKET/metadata/*"
      ]
    }
  ]
}
